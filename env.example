# ========================================
# CONFIGURATION HERMES
# ========================================

# ── Discord Bot (OBLIGATOIRE) ──────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=

# ── Discord OAuth2 (OBLIGATOIRE pour le site web) ─────────────────
# Créer une application sur https://discord.com/developers/applications
# Ajouter le redirect URI : http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── BetterAuth (OBLIGATOIRE) ──────────────────────────────────────
# Générer un secret aléatoire : openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API & JWT ─────────────────────────────────────────────────────
BLAGUES_API_TOKEN=your_blagues_api_token_here
BOT_API_TOKEN=shared-secret-between-web-api-and-bot

# ── PostgreSQL (OBLIGATOIRE) ──────────────────────────────────────
PG_HOST=db
PG_PORT=5432
PG_DB=hermes
PG_USER=hermes
PG_PASSWORD=change_me

# ── URLs frontend ─────────────────────────────────────────────────
# Proxy interne Next.js — ne pas mettre http://…:8000 en production
NEXT_PUBLIC_API_URL=/api/proxy

# ── Canaux Discord ────────────────────────────────────────────────
BOT_CHANNEL_START=
LOG_CHANNEL_ID=
VOICE_LOG_CHANNEL_ID=
CONFESSION_CHANNEL_ID=
ANIME_NEWS_CHANNEL_ID=
BUMP_CHANNEL_ID=1068608173310754886
WELCOME_CHANNEL_ID=
MEMBER_LOGS_CHANNEL_ID=
COMMAND_LOG_CHANNEL_ID=
ADMIN_LOG_CHANNEL_ID=
SANCTION_LOG_CHANNEL_ID=
ROLE_LOG_CHANNEL_ID=
CONFESSION_LOG_CHANNEL_ID=
ACHIEVEMENTS_CHANNEL_ID=

# ── Rôles Discord ─────────────────────────────────────────────────
ADMIN_ROLE_NAME=Administration
REDACTEUR_ROLE_NAME=rédacteur
AUTHORIZED_ROLES=GroFlex,Généraux saucisses
ROLE_BATMAN=Batman
VOICE_HOURS_FOR_ROLE=100

# ── Divers ────────────────────────────────────────────────────────
ANIME_THUMBNAIL_URL=
ANIME_AUTHOR_AVATAR_URL=
DEFAULT_COMMAND_STATE=true
